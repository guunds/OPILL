# ════════════════════════════════════════
# OPiLL Protocol Backend — Environment
# ════════════════════════════════════════

PORT=3001
NETWORK=testnet4

# ── Bitcoin Core RPC ─────────────────────
# Port testnet4 default: 48332
BTC_RPC_HOST=127.0.0.1
BTC_RPC_PORT=48332
BTC_RPC_USER=bitcoin
BTC_RPC_PASS=bitcoin

# ── OP_NET Node ──────────────────────────
# Kalau kamu jalankan OP_NET node lokal
OPNET_URL=http://127.0.0.1:9001

# ── Frontend ─────────────────────────────
FRONTEND_URL=https://opill-protocol.vercel.app

# ── Token Contract Addresses (Testnet4) ──
# GANTI dengan contract address asli dari project kamu!
# Contoh format: bcrt1p... atau tb1p...
CONTRACT_OPILL=GANTI_DENGAN_CONTRACT_OPILL
CONTRACT_PILL=GANTI_DENGAN_CONTRACT_PILL
CONTRACT_MOTO=GANTI_DENGAN_CONTRACT_MOTO
CONTRACT_NFT=GANTI_DENGAN_CONTRACT_NFT
